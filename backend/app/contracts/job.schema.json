{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Job",
  "type": "object",
  "required": ["id", "title", "company", "apply_url", "platform", "created_at"],
  "properties": {
    "id": { "type": "integer" },
    "title": { "type": "string", "maxLength": 300 },
    "company": { "type": "string", "maxLength": 200 },
    "location": { "type": ["string", "null"] },
    "description": { "type": ["string", "null"] },
    "requirements": { "type": "array", "items": { "type": "string" } },
    "salary_range": { "type": ["string", "null"] },
    "apply_url": { "type": "string" },
    "platform": { "type": "string", "enum": ["linkedin", "indeed", "naukri", "google", "company", "glassdoor", "hidden", "other"] },
    "source_url": { "type": ["string", "null"] },
    "is_easy_apply": { "type": "boolean" },
    "is_hidden_job": { "type": "boolean" },
    "match_score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "skill_match_pct": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "priority_score": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
    "status": { "type": "string", "enum": ["not_applied", "saved", "applied", "interview", "rejected", "offered"] },
    "created_at": { "type": "string", "format": "date-time" }
  }
}
